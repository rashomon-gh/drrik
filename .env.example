# Environment Configuration for Drrik Framework
#
# Copy this file to .env and fill in your API keys and tokens.
# The .env file is git-ignored to protect your credentials.

# ============================================================================
# HuggingFace Hub Configuration
# ============================================================================

# Your HuggingFace Hub API token.
# Required for accessing gated models like Llama 2, Llama 3, Mistral, etc.
# Get your token at: https://huggingface.co/settings/tokens
#
# Format: hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_HUB_TOKEN=your_huggingface_token_here

# ============================================================================
# Weights & Biases Configuration
# ============================================================================

# Your Weights & Biases API key for experiment tracking.
# Required if you want to use wandb for logging SAE training.
# Get your key at: https://wandb.ai/settings
#
# Format: a bunch of alphanumeric characters
WANDB_API_KEY=your_wandb_api_key_here

# Default wandb project name for experiments
WANDB_PROJECT=drrik-experiments

# Optional: Your wandb entity (username or team name)
# If not specified, uses your default wandb username
# WANDB_ENTITY=your-username-or-team

# wandb mode: 'online' to sync to cloud, 'offline' to save locally,
# or 'disabled' to completely disable wandb
WANDB_MODE=online

# ============================================================================
# Optional: Additional Configuration
# ============================================================================

# Optional: Custom cache directory for HuggingFace models
# TRANSFORMERS_CACHE=/path/to/cache

# Optional: Override default device (cuda, cpu, auto)
# DRIK_DEFAULT_DEVICE=auto

# Optional: Log level for debugging (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
